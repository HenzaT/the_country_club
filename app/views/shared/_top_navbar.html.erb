<div class="topnav">
  <% if user_signed_in? %>
    <%= link_to root_path, class: "nav-link" do %>
      <i class="fa-regular fa-map" alt="map icon" id="nav-map-icon"></i>
    <% end %>
    <%= render "shared/continent_links" %>
    <div class="options-overlay" data-navbar-target="optionsOverlay">
      <%= link_to "Member's Area", dashboard_path, class: "nav-link" %>
      <%= link_to "Logout", destroy_user_session_path, data: { turbo_method: :delete }, class: "nav-link" %>
    </div>
  <% else %>
    <%= link_to root_path, class: "nav-link active" do %>
      <i class="fa-regular fa-map" alt="map icon" id="nav-map-icon"></i>
    <% end %>
    <%= render "shared/continent_links" %>
    <%= link_to "Login", new_user_session_path, class: "nav-link nav-right" %>
  <% end %>
</div>
