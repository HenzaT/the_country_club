<div class="user-forms">
  <h1 class="form-header">Log in</h1>

  <%= simple_form_for(resource, as: resource_name, url: session_path(resource_name), class: "form") do |f| %>
    <%= f.input :email,
                required: false,
                autofocus: true,
                input_html: { autocomplete: "email" },
                placeholder: "type email here...",
                class: "email" %>
    <div class="password">
      <%= f.label :password %>
      <div class="password-input">
        <%= f.input_field :password,
                    required: false,
                    input_html: { autocomplete: "current-password" },
                    placeholder: "type password here...",
                    class: "password" %>
        <button type="button"><%= image_tag 'eye.svg' %></button>
      </div>
    </div>
    <%= f.input :remember_me, class: "remember-me", as: :boolean if devise_mapping.rememberable? %>

    <%= f.button :submit, "Log in", class: "submit-button" %>
  <% end %>

  <%= render "devise/shared/links" %>
</div>
